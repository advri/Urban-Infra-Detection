APP_NAME=Urban Infra Detection API
APP_VERSION=1.0.0
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MODEL_PATH=./models/model.onnx
MODEL_INPUT_SIZE=1024

MODEL_LABELS=plane,baseball-diamond,bridge,ground-track-field,small-vehicle,large-vehicle,ship,tennis-court,basketball-court,storage-tank,soccer-ball-field,roundabout,harbor,swimming-pool,helicopter,container-crane,airport,helipad

CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

ONNX_PROVIDERS=CPUExecutionProvider
# GPU: ONNX_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider

MODEL_HAS_OBJECTNESS=false
MODEL_ANGLE_IN_DEGREES=false
MODEL_OUTPUT_INDEX=0
NORMALIZE_01=true
MODEL_PREDECODED=true

TRACKER_MAX_DISAPPEARED=30
TRACKER_MAX_DISTANCE=100.0
TRACKER_POLYGON=0.2,0.2;0.8,0.2;0.8,0.8;0.2,0.8
TRACKER_HIGH_THRESH=0.5
TRACKER_LOW_THRESH=0.1
TRACKER_NEW_TRACK_THRESH=0.5
TRACKER_MATCH_IOU_THRESHOLD=0.15

TRACKER_MIN_HITS=2

MIN_DET_AREA=10.0

MAX_DET_ASPECT_RATIO=8.0

DEFAULT_FPS=30.0

MAX_IMAGE_SIZE_BYTES=10485760
MAX_VIDEO_SIZE_BYTES=209715200
UPLOAD_CHUNK_SIZE_BYTES=1048576
TEMP_DIR=artifacts/tmp
VIDEO_OUTPUT_DIR=artifacts/video

PIPELINE_FACTORY=inference.engine:create_pipeline

ENABLE_LEGACY_HEALTH_ENDPOINT=true
